# ── SERVER ──
PORT=3000
FRONTEND_URL=https://yourwebsite.com   # or * for development

# ── JWT SECRET (change this to a long random string in production!) ──
JWT_SECRET=change-this-to-a-long-random-secret-string

# ── SMTP EMAIL (Gmail example) ──
# For Gmail: enable 2FA and create an App Password at https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password

# ── WHERE CONTACT EMAILS GET SENT ──
CONTACT_EMAIL=hello@manjugroups.com
